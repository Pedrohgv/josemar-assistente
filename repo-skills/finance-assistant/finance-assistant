#!/usr/bin/env python3

import sys
import os
import json
import traceback

lib_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'lib')
if lib_dir not in sys.path:
    sys.path.insert(0, lib_dir)

def action_register(data):
    pdf_path = data.get('pdf_path')
    month = data.get('month')
    year = data.get('year')

    if not all([pdf_path, month, year]):
        return {"success": False, "error": "Missing required fields: pdf_path, month, year"}

    if not os.path.exists(pdf_path):
        return {"success": False, "error": f"PDF not found: {pdf_path}"}

    from pdf_extractor import extract_text
    from expense_parser import extract_total, extract_expenses
    from classifier import classify_expenses
    from sheets_writer import append_expenses

    try:
        raw_text = extract_text(pdf_path)
    except Exception as e:
        return {"success": False, "error": f"Failed to extract PDF text: {e}"}

    total_str = extract_total(raw_text)
    if not total_str:
        return {"success": False, "error": "Could not extract total from PDF"}

    expenses = extract_expenses(raw_text, total_str)
    if not expenses:
        return {"success": False, "error": "No expenses found in PDF"}

    classified, unclassified = classify_expenses(expenses)

    result = append_expenses(year, month, classified)
    if not result['success']:
        return result

    result['unclassified'] = unclassified if unclassified else None
    result['total_expense'] = total_str
    return result


def action_add_establishment(data):
    from classifier import add_establishment as add_est
    name = data.get('name')
    pattern = data.get('pattern')
    category = data.get('category')
    exclude = data.get('exclude')

    if not all([name, pattern, category]):
        return {"success": False, "error": "Missing required fields: name, pattern, category"}

    ok, msg = add_est(name, pattern, category, exclude)
    return {"success": ok, "message": msg}


def action_remove_establishment(data):
    from classifier import remove_establishment as remove_est
    name = data.get('name')
    if not name:
        return {"success": False, "error": "Missing required field: name"}

    ok, msg = remove_est(name)
    return {"success": ok, "message": msg}


def action_list_establishments(_data):
    from classifier import list_establishments
    return {"success": True, "establishments": list_establishments()}


def action_list_categories(_data):
    from classifier import list_categories
    return {"success": True, "categories": list_categories()}


ACTIONS = {
    'register': action_register,
    'add_establishment': action_add_establishment,
    'remove_establishment': action_remove_establishment,
    'list_establishments': action_list_establishments,
    'list_categories': action_list_categories,
}


def main():
    try:
        input_data = sys.stdin.read().strip()

        if not input_data:
            result = {
                "success": False,
                "error": "No input provided",
                "usage": {
                    "description": "Finance Assistant - credit card expense tracking",
                    "actions": [
                        {"action": "register", "description": "Extract, classify and register expenses from PDF", "example": '{"action": "register", "pdf_path": "/path/to/invoice.pdf", "month": "Jan", "year": 2025}'},
                        {"action": "add_establishment", "description": "Add establishment pattern", "example": '{"action": "add_establishment", "name": "Uber", "pattern": "uber", "category": "Transporte"}'},
                        {"action": "remove_establishment", "description": "Remove establishment pattern", "example": '{"action": "remove_establishment", "name": "Uber"}'},
                        {"action": "list_establishments", "description": "List all establishment patterns"},
                        {"action": "list_categories", "description": "List all categories"},
                    ],
                },
            }
            print(json.dumps(result, indent=2, ensure_ascii=False))
            sys.exit(1)

        try:
            data = json.loads(input_data)
        except json.JSONDecodeError as e:
            result = {"success": False, "error": f"Invalid JSON: {e}"}
            print(json.dumps(result, indent=2, ensure_ascii=False))
            sys.exit(1)

        action = data.get('action')
        handler = ACTIONS.get(action)

        if not handler:
            result = {
                "success": False,
                "error": f"Unknown action: {action}",
                "valid_actions": list(ACTIONS.keys()),
            }
            print(json.dumps(result, indent=2, ensure_ascii=False))
            sys.exit(1)

        result = handler(data)
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(0 if result.get('success') else 1)

    except Exception as e:
        result = {"success": False, "error": str(e), "traceback": traceback.format_exc()}
        print(json.dumps(result, indent=2, ensure_ascii=False))
        sys.exit(1)


if __name__ == '__main__':
    main()
