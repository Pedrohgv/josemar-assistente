// OpenClaw configuration for Josemar Assistente
// JSON5 format allows comments and trailing commas

{
  // Environment variables for API keys
  env: {
    ZAI_API_KEY: "${ZAI_API_KEY}",
    TELEGRAM_BOT_TOKEN: "${TELEGRAM_BOT_TOKEN}",
    DEEPSEEK_API_KEY: "${DEEPSEEK_API_KEY}",
  },

  // Gateway configuration
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    auth: {
      mode: "token",
      token: "${GATEWAY_AUTH_TOKEN}",
    },
  },

  // Model providers configuration
  models: {
    mode: "merge",
    providers: {
      // Custom provider for DeepSeek (OpenAI-compatible)
      deepseek: {
        baseUrl: "https://api.deepseek.com/v1",
        apiKey: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek-chat",
            name: "DeepSeek Chat",
            reasoning: false,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 8192,
          },
          {
            id: "deepseek-reasoner",
            name: "DeepSeek Reasoner",
            reasoning: true,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 64000,
          },
        ],
      },
      // Z.AI provider for GLM models
      zai: {
        baseUrl: "https://api.z.ai/api/paas/v4",
        apiKey: "${ZAI_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "glm-5",
            name: "GLM 5",
            reasoning: false,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 8192,
          },
          {
            id: "glm-4.7",
            name: "GLM 4.7",
            reasoning: false,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  // Agent configuration
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "zai/glm-5",
        fallbacks: ["zai/glm-4.7", "deepseek/deepseek-chat", "deepseek/deepseek-reasoner"],
      },
      models: {
        "zai/glm-5": {
          alias: "GLM 5",
        },
        "zai/glm-4.7": {
          alias: "GLM 4.7",
        },
        "deepseek/deepseek-chat": {
          alias: "DeepSeek Chat",
        },
        "deepseek/deepseek-reasoner": {
          alias: "DeepSeek Reasoner",
        },
      },
    },
    list: [
      {
        id: "josemar",
        default: true,
        name: "Josemar",
        workspace: "~/.openclaw/workspace",
        model: "zai/glm-5",
        identity: {
          name: "Josemar",
          theme: "helpful assistant",
          emoji: "🤕",
        },
      },
    ],
  },

  // Channel configurations
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      // To add more users, add their {NAME}_TELEGRAM_ID env var and include it here:
      allowFrom: [
        "${PEDRO_TELEGRAM_ID}",
        // "${ALICE_TELEGRAM_ID}",
        // "${BOB_TELEGRAM_ID}",
      ],
    },
  },

  // Skills configuration
  skills: {
    entries: {
      "pdf-extractor": {
        enabled: true,
      },
    },
  },

  // Session configuration
  session: {
    scope: "per-sender",
    reset: {
      mode: "idle",
      idleMinutes: 60,
    },
    store: "~/.openclaw/agents/josemar/sessions/sessions.json",
  },

  // Logging configuration
  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "pretty",
    redactSensitive: "tools",
  },
}
