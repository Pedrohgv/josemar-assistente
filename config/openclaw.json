// OpenClaw configuration for Josemar Assistente
// JSON5 format allows comments and trailing commas

{
  // Environment variables for API keys
  env: {
    ZAI_API_KEY: "${ZAI_API_KEY}",
    TELEGRAM_BOT_TOKEN: "${TELEGRAM_BOT_TOKEN}",
    DEEPSEEK_API_KEY: "${DEEPSEEK_API_KEY}",
    OLLAMA_API_KEY: "${OLLAMA_API_KEY}",
    GOG_KEYRING_PASSWORD: "${GOG_KEYRING_PASSWORD}",
  },

  // Gateway configuration
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    auth: {
      mode: "password",
      password: "${GATEWAY_AUTH_PASSWORD}",
    },
    controlUi: {
      allowedOrigins: [
        "http://192.168.15.200:18789",
        "http://localhost:18789",
        "https://josemar.casabanana.casa",
      ],
    },
  },

  // Model providers configuration
  models: {
    mode: "merge",
    providers: {
      // Custom provider for DeepSeek (OpenAI-compatible)
      deepseek: {
        baseUrl: "https://api.deepseek.com/v1",
        apiKey: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek-chat",
            name: "DeepSeek Chat",
            reasoning: false,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 8192,
          },
          {
            id: "deepseek-reasoner",
            name: "DeepSeek Reasoner",
            reasoning: true,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 64000,
          },
        ],
      },
      // Ollama Cloud provider (OpenAI-compatible)
      ollama: {
        baseUrl: "https://ollama.com/v1",
        apiKey: "${OLLAMA_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "glm-5.1:cloud",
            name: "GLM 5.1 Cloud",
            reasoning: false,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 32768,
          },
          {
            id: "kimi-k2.5:cloud",
            name: "Kimi K2.5 Cloud",
            reasoning: true,
            input: ["text", "image"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 32768,
          },
          {
            id: "kimi-k2.6:cloud",
            name: "Kimi K2.6 Cloud",
            reasoning: true,
            input: ["text", "image"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 32768,
          },
          {
            id: "minimax-m2.7:cloud",
            name: "MiniMax M2.7 Cloud",
            reasoning: true,
            input: ["text"],
            cost: {
              input: 0,
              output: 0,
              cacheRead: 0,
              cacheWrite: 0,
            },
            contextWindow: 128000,
            maxTokens: 32768,
          },
        ],
      },
      // Z.AI provider for GLM models
      zai: {
        baseUrl: "https://api.z.ai/api/coding/paas/v4",
        apiKey: "${ZAI_API_KEY}",
        api: "openai-completions",
        models: [
          {
            "id": "glm-5",
            "name": "GLM-5",
            "reasoning": false,
            "input": ["text"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 204800,
            "maxTokens": 131072
          },
          {
            "id": "glm-5.1",
            "name": "GLM-5.1",
            "reasoning": false,
            "input": ["text"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 204800,
            "maxTokens": 131072
          },
          {
            "id": "glm-4.7",
            "name": "GLM-4.7",
            "reasoning": false,
            "input": ["text"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 204800,
            "maxTokens": 131072
          },
          {
            "id": "glm-5-turbo",
            "name": "GLM-5-Turbo",
            "reasoning": false,
            "input": ["text"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 204800,
            "maxTokens": 131072
          },
        ],
      },
    },
  },

  // Agent configuration
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      userTimezone: "${JOSEMAR_TIMEZONE}",
      envelopeTimezone: "${JOSEMAR_TIMEZONE}",
      model: {
        primary: "ollama/kimi-k2.6:cloud",
        fallbacks: ["zai/glm-5", "zai/glm-4.7", "deepseek/deepseek-chat", "ollama/glm-5.1:cloud"],
      },
      imageModel: "ollama/kimi-k2.5:cloud",
      models: {
        "zai/glm-5.1": {
          alias: "GLM 5.1",
        },
        "zai/glm-5": {
          alias: "GLM 5",
        },
        "zai/glm-4.7": {
          alias: "GLM 4.7",
        },
        "deepseek/deepseek-chat": {
          alias: "DeepSeek Chat",
        },
        "deepseek/deepseek-reasoner": {
          alias: "DeepSeek Reasoner",
        },
        "zai/glm-5-turbo": {
          alias: "GLM 5 Turbo",
        },
        "ollama/glm-5.1:cloud": {
          alias: "GLM 5.1 Cloud (Ollama)",
        },
        "ollama/kimi-k2.5:cloud": {
          alias: "Kimi K2.5 Cloud (Ollama)",
        },
        "ollama/kimi-k2.6:cloud": {
          alias: "Kimi K2.6 Cloud (Ollama)",
        },
        "ollama/minimax-m2.7:cloud": {
          alias: "MiniMax M2.7 Cloud (Ollama)",
        },
      },
    },
    list: [
      {
        id: "josemar",
        default: true,
        name: "Josemar",
        workspace: "~/.openclaw/workspace",
        model: "ollama/kimi-k2.6:cloud",
      },
    ],
  },

  // Channel configurations
  channels: {
    telegram: {
      enabled: "${TELEGRAM_ENABLED}",
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      // To add more users, add their {NAME}_TELEGRAM_ID env var and include it here:
      allowFrom: [
        "${PEDRO_TELEGRAM_ID}",
        // "${ALICE_TELEGRAM_ID}",
        // "${BOB_TELEGRAM_ID}",
      ],
    },
  },

  // Skills configuration
  skills: {
    allowBundled: [],
    load: {
      extraDirs: [
        "/opt/josemar/skills",
      ],
      watch: true,
      watchDebounceMs: 250,
    },
    entries: {},
  },

  // Cron jobs (tracked in state repo workspace)
  cron: {
    enabled: true,
    store: "~/.openclaw/workspace/cron/jobs.json",
  },

  // Session configuration
  session: {
    scope: "per-sender",
    reset: {
      mode: "idle",
      idleMinutes: 60,
    },
    store: "~/.openclaw/agents/josemar/sessions/sessions.json",
  },

  // Logging configuration
  logging: {
    level: "info",
    consoleLevel: "info",
    consoleStyle: "pretty",
    redactSensitive: "tools",
  },
}
