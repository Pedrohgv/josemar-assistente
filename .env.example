# Environment variables for Josemar Assistente OpenClaw bot

# Z.AI API Key for GLM models (get from https://z.ai)
ZAI_API_KEY=your_zai_api_key_here

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Channel Control (optional)
# Set to 'false' for local testing to avoid conflicts with production bot
# Default: 'true' (enabled in production)
TELEGRAM_ENABLED=true

# Telegram User ID for the primary user (admin)
# This user will be pre-approved to chat with the bot without pairing
# Get your ID from @userinfobot on Telegram
PRIMARY_TELEGRAM_ID=123456789

# Additional users can be added following the pattern: {NAME}_TELEGRAM_ID
# Example:
# ALICE_TELEGRAM_ID=987654321
# BOB_TELEGRAM_ID=555666777
# Then add them to config/openclaw.json channels.telegram.allowFrom array

# DeepSeek API Key (optional, if using DeepSeek provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Ollama Cloud API Key (optional, for Ollama Cloud provider)
OLLAMA_API_KEY=your_ollama_api_key_here

# Gateway Authentication Password (required for UI access)
# Uses HTTP Basic Auth (more secure than URL tokens for Cloudflare Tunnel)
# Generate a secure password
GATEWAY_AUTH_PASSWORD=your-secure-password-here

# Optional allowed origins for OpenClaw Web UI (production)
# Keep localhost hardcoded in config/openclaw.json for local access
CONTROL_UI_ALLOWED_ORIGIN_1=https://your-domain.example
CONTROL_UI_ALLOWED_ORIGIN_2=http://your-server-ip:18789

# OpenClaw log level (debug, info, warn, error)
OPENCLAW_LOG_LEVEL=info

# Josemar timezone (IANA format, defaults to America/Sao_Paulo / UTC-3)
# Used for agent system prompts, message envelope timestamps, and container clock
JOSEMAR_TIMEZONE=America/Sao_Paulo

# GOG Keyring Password (optional, for gogcli OAuth token decryption)
# Used by gogcli keyring to decrypt the local Google OAuth token store
GOG_KEYRING_PASSWORD=your_gog_keyring_password_here

# =============================================
# Auxiliary ML Container (Optional)
# =============================================
# Feature flag consumed by Josemar skills
AUX_ML_ENABLED=false

# Compose profile activation for optional aux-ml service
# Set to "aux-ml" to start/build the auxiliary container
COMPOSE_PROFILES=

# Optional build-time overrides.
# If local files are absent and these are left empty, compose defaults download:
# - GLM-OCR-Q8_0.gguf
# - mmproj-GLM-OCR-Q8_0.gguf
AUX_ML_GLM_OCR_URL=
AUX_ML_GLM_OCR_SHA256=
AUX_ML_GLM_OCR_MMPROJ_URL=
AUX_ML_GLM_OCR_MMPROJ_SHA256=

# Internal service URL used by the aux-ml skill from OpenClaw container
AUX_ML_URL=http://aux-ml:8091

# Memory budget for the aux-ml container.
# Keep this aligned with AUX_ML_MEMORY_LIMIT_MB and largest model requirement.
AUX_ML_MEMORY_LIMIT=8192m
AUX_ML_MEMORY_LIMIT_MB=8192

# Queue and job controls
AUX_ML_MAX_QUEUE=50
AUX_ML_JOB_TIMEOUT_SECONDS=1800
AUX_ML_POLL_INTERVAL_SECONDS=2

# llama.cpp server read/write timeout used by aux-ml router and child model server
# Increase this when OCR requests can exceed 10 minutes.
AUX_ML_LLAMACPP_TIMEOUT_SECONDS=1800

# Security/limits for file-based OCR jobs
AUX_ML_ALLOWED_INPUT_DIRS=/root/.openclaw/workspace
AUX_ML_ENFORCE_MEMORY_LIMIT=true
AUX_ML_OCR_MAX_PAGES=50

# =============================================
# Obsidian Vault Infrastructure
# =============================================
# Tailscale auth key used by tailscale sidecar for unattended login
# Generate in https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Node identity/options for tailscale sidecar (optional)
TAILSCALE_HOSTNAME=josemar-server
TS_EXTRA_ARGS=

# Timezone used by Syncthing and backup scheduler
TZ=America/Sao_Paulo

# Syncthing GUI/API bind IP (security default: localhost only)
# Keep 127.0.0.1 and use SSH tunnel for remote admin access
SYNCTHING_GUI_BIND_IP=127.0.0.1

# Daily backup time in 24h format (HH:MM)
OBSIDIAN_BACKUP_TIME=03:15

# Run one backup immediately on container startup
OBSIDIAN_BACKUP_RUN_ON_START=false

# Number of rotating backup slots kept in Google Drive
OBSIDIAN_BACKUP_SLOTS=5

# rclone remote name and destination path in Google Drive
OBSIDIAN_GDRIVE_REMOTE=gdrive
OBSIDIAN_GDRIVE_PATH=Josemar/obsidian-backups

# =============================================
# Agent State Repository Configuration
# =============================================
# URL of the private git repo that stores agent state (workspace files, skills, memory)
# Create a private repo and set this to its HTTPS clone URL
WORKSPACE_STATE_REPO=https://github.com/username/josemar-agent-state.git

# GitHub PAT with repo access (set via GitHub secret WORKSPACE_REPO_TOKEN in deployment)
# For local development, set directly here (not recommended for production)
WORKSPACE_REPO_TOKEN=

# Git sync on container start (set to 'false' to skip sync)
WORKSPACE_SYNC_ON_START=true

# Periodic sync interval in minutes (set to 0 to disable)
WORKSPACE_SYNC_INTERVAL=60

# Number of days to keep memory log files (older files are removed)
WORKSPACE_MEMORY_DAYS=30

# Git branch to use
WORKSPACE_GIT_BRANCH=main

# Git identity for auto-commits
WORKSPACE_GIT_USER_EMAIL=agent@josemar.local
WORKSPACE_GIT_USER_NAME=Josemar Agent
