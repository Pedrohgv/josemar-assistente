# Environment variables for Josemar Assistente OpenClaw bot

# Z.AI API Key for GLM models (get from https://z.ai)
ZAI_API_KEY=your_zai_api_key_here

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Channel Control (optional)
# Set to 'false' for local testing to avoid conflicts with production bot
# Default: 'true' (enabled in production)
TELEGRAM_ENABLED=true

# Telegram User ID for the primary user (Pedro)
# This user will be pre-approved to chat with the bot without pairing
# Get your ID from @userinfobot on Telegram
PEDRO_TELEGRAM_ID=190731460

# Additional users can be added following the pattern: {NAME}_TELEGRAM_ID
# Example:
# ALICE_TELEGRAM_ID=987654321
# BOB_TELEGRAM_ID=555666777
# Then add them to config/openclaw.json channels.telegram.allowFrom array

# DeepSeek API Key (optional, if using DeepSeek provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gateway Authentication Token (required for UI access)
# Generate a secure token with: openssl rand -hex 32
# This token is required to access the OpenClaw web UI when exposed
GATEWAY_AUTH_TOKEN=your-generated-token-here

# OpenClaw log level (debug, info, warn, error)
OPENCLAW_LOG_LEVEL=info

# GOG Keyring Password (optional, for GOG Galaxy integration)
# Used for decrypting GOG credentials store for game library access
GOG_KEYRING_PASSWORD=your_gog_keyring_password_here

# Telegram user ID for pairing (optional)
# TELEGRAM_USER_ID=123456789

# Skills deployment configuration (optional)
# Comma-separated list of skill names to force overwrite from repo
# Use when you want to reset specific skills to their repo version
# Example: FORCE_OVERWRITE_SKILLS=pdf-extractor,web-scraper
FORCE_OVERWRITE_SKILLS=
